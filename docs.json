{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bluprynt Docs",
  "description": "The Compliance OS for Digital Assets. Documentation for Bluprynt's identity, disclosures, supervision, and credentials platform.",
  "colors": {
    "primary": "#007BFF",
    "light": "#3B9CFF",
    "dark": "#0056B3"
  },
  "favicon": "/favicon.svg",
  "seo": {
    "indexing": "all"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "overview/what-is-bluprynt",
              "overview/architecture",
              "overview/key-concepts",
              "overview/standards-compatibility"
            ]
          },
          {
            "group": "Getting started",
            "pages": [
              "quickstart",
              "getting-started/create-account",
              "getting-started/your-first-attestation"
            ]
          },
          {
            "group": "Core products",
            "pages": [
              {
                "group": "Know Your Issuer (KYI)",
                "icon": "id-card",
                "pages": [
                  "core-products/kyi/introduction",
                  "core-products/kyi/how-it-works",
                  "core-products/kyi/widget-embed"
                ]
              },
              {
                "group": "Smart Disclosures",
                "icon": "file-contract",
                "pages": [
                  "core-products/smart-disclosures/introduction",
                  "core-products/smart-disclosures/document-lifecycle"
                ]
              },
              {
                "group": "Compliance Hub",
                "icon": "shield-halved",
                "pages": [
                  "core-products/compliance-hub/introduction"
                ]
              },
              {
                "group": "MiCA Checker",
                "icon": "circle-check",
                "pages": [
                  "core-products/mica-checker/introduction"
                ]
              }
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture/system-overview",
              "architecture/attestation-schemas",
              "architecture/policy-engine",
              "architecture/ccid"
            ]
          },
          {
            "group": "Integration guides",
            "pages": [
              "integration-guides/overview",
              "integration-guides/kyi-widget",
              "integration-guides/public-api"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication",
              "api-reference/rate-limits",
              "api-reference/errors"
            ]
